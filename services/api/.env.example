# Comma-separated list of allowed origins for browser clients.
OPEN_REGATTA_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173

# Optional: directory containing gps-sample.json, weather-sample.json, polar-sample.json.
# If unset, defaults to ../../data/examples relative to this service.
OPEN_REGATTA_DATA_DIR=
